                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid payload returns client error', function () { pm.expect([400, 422]).to.include(pm.response.code); });",
                  "pm.test('Error body is parseable and structured', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('object');",
                  "  const hasProblemStatus = Object.prototype.hasOwnProperty.call(json, 'status');",
                  "  const hasPrismErrors = Array.isArray(json.errors);",
                  "  pm.expect(hasProblemStatus || hasPrismErrors).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
