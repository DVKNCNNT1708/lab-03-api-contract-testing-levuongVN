    {
      "name": "02_Auth",
      "item": [
        {
          "name": "POST /ingest - missing token rejected on local",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/ingest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ingest"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceType\": \"iot\",\n  \"deviceId\": \"IOT-ESP32-001\",\n  \"metric\": \"temperature\",\n  \"value\": 29.4,\n  \"unit\": \"celsius\",\n  \"occurredAt\": \"2026-05-20T08:30:00Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not enforce auth middleware', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Missing token returns 401 or 403', function () { pm.expect([401, 403]).to.include(pm.response.code); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /analytics/summary - invalid token rejected on local",
          "request": {
            "method": "GET",
            "header": [
