                  "key": "toDate",
                  "value": "2026-05-26"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: invalid token requires real service auth', function () { pm.expect(true).to.eql(true); });",
